# Copy this file to .env and fill in local secrets.
# Never commit .env.

# PostgreSQL settings used by docker-compose and local API overrides.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=creditmosaic
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Local service ports.
API_PORT=8000
WEB_PORT=3000

# Longcat OpenAI-compatible provider.
# Keep the real key only in .env or your shell environment.
LONGCAT_API_KEY=
